[alias]
    patch = !git --no-pager diff --no-color

[user]
	name = Liran Tal
	username = lirantal
	email = liran.tal@gmail.com
	signingkey = /Users/lirantal/.ssh/id_ed25519.pub
[color]
	ui = true
[core]
	editor = vim
	excludesfile = /Users/lirantal/.gitignore
	ignorecase = false
	filemode = true
[pull]
	ff = false
	rebase = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
[commit]
	gpgsign = true
[gpg]
	format = ssh
[tag]
	forceSignAnnotated = true
[http]
	postBuffer = 524288000
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
